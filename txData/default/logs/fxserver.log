[      script:kw_core]             ALTER COLUMN inventory   TYPE JSONB USING COALESCE(NULLIF(inventory,''),'null')::JSONB,
[      script:kw_core]             ALTER COLUMN loadout     TYPE JSONB USING COALESCE(NULLIF(loadout,''),'null')::JSONB,
[      script:kw_core]             ALTER COLUMN skin        TYPE JSONB USING COALESCE(NULLIF(skin,''),'null')::JSONB,
[      script:kw_core]             ALTER COLUMN position    TYPE JSONB USING COALESCE(NULLIF(position,''),'null')::JSONB;
