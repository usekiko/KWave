[      script:kw_core]     sex           VARCHAR(1)   DEFAULT NULL,
[      script:kw_core]     height        INTEGER      DEFAULT NULL,
[      script:kw_core]     created_at    TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
[      script:kw_core]     updated_at    TIMESTAMPTZ  NOT NULL DEFAULT NOW()
[      script:kw_core] );
[      script:kw_core] 
[      script:kw_core] -- Ensure JSONB types (safe on fresh DB, also fixes any old TEXT columns)
[      script:kw_core] DO $$ BEGIN
